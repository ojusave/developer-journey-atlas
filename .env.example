# Browser build
VITE_ADAPTIVE_ENABLED=true

# Web service
NODE_ENV=development
PORT=10000
ALLOW_IN_MEMORY_STORE=true
SESSION_TTL_HOURS=24
TURN_ENVELOPE_TTL_SECONDS=900

# Required for persistent or production storage
DATABASE_URL=
SESSION_ENVELOPE_KEY=

# Safe defaults. Enable only after the live provider gates in README.md pass.
REASONING_MODE=deterministic
DIAGNOSTIC_MODEL=
OPENROUTER_API_KEY=

# Safe default. Render Workflows are feature-gated per turn.
EXECUTION_MODE=direct
RENDER_API_KEY=
RENDER_WORKFLOW_TASK_SLUG=
WORKFLOW_DISPATCH_TIMEOUT_MS=10000
INTERNAL_WORKFLOW_SECRET=

# Optional origin and proxy controls
APP_ORIGIN=
TRUST_PROXY=false
RATE_LIMIT_WINDOW_SECONDS=60
SESSION_CREATE_LIMIT=300
SESSION_TURN_LIMIT=30
IP_TURN_LIMIT=1200

# Optional metadata-only Arize export
ARIZE_TELEMETRY_ENABLED=false
ARIZE_API_KEY=
ARIZE_SPACE_ID=
ARIZE_PROJECT_NAME=first-mile-scanner
ARIZE_OTLP_ENDPOINT=https://otlp.arize.com/v1/traces
