{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developer-journey-atlas.invalid/comparison-record.schema.json",
  "title": "Developer Journey Atlas internal comparison record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "comparison_id",
    "subject_journey_id",
    "peer_journey_ids",
    "matching_dimensions",
    "differing_dimensions",
    "source_ids",
    "limitations",
    "analysis_eligible",
    "safe_to_anonymize",
    "participant_summary"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "comparison_id": {"type": "string", "pattern": "^comparison:[a-z0-9:-]+$"},
    "subject_journey_id": {"type": "string", "pattern": "^journey:[a-z0-9-]+:[a-z0-9-]+$"},
    "peer_journey_ids": {"type": "array", "items": {"type": "string", "pattern": "^journey:[a-z0-9-]+:[a-z0-9-]+$"}, "uniqueItems": true},
    "matching_dimensions": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/dimension"}},
    "differing_dimensions": {"type": "array", "items": {"$ref": "#/$defs/dimension"}},
    "source_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "analysis_eligible": {"type": "boolean"},
    "safe_to_anonymize": {"type": "boolean"},
    "participant_summary": {"type": ["string", "null"]}
  },
  "$defs": {
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "subject_value", "peer_values", "source_ids"],
      "properties": {
        "name": {
          "enum": ["platform-archetype", "developer-goal", "authentication-model", "credential-model", "setup-surface", "execution-model", "first-operation", "success-verification", "account-gate", "entitlement-gate", "branch-complexity"]
        },
        "subject_value": {"type": "string"},
        "peer_values": {"type": "array", "items": {"type": "string"}},
        "source_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
      }
    }
  }
}
