# Phase 1 needs none of these. Phase 2 (live research for unknown platforms)
# reads them. Copy to .env for local dev; set as sync:false secrets on Render.

# Turn on the live-research pipeline.
RESEARCH_ENABLED=false

# You.com Web Search API key. Get one at https://you.com/platform
YDC_API_KEY=

# OpenRouter API key for LLM record reconstruction. https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Optional: override the OpenRouter model used to reconstruct records.
OPENROUTER_MODEL=openai/gpt-4o

# Optional: GitHub token to open draft PRs adding newly researched records.
# Without it, research still runs and the drafted record is offered for manual
# submission. Needs contents:write + pull_requests:write on the dataset repo.
GITHUB_TOKEN=
