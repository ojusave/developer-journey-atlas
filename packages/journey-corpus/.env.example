# Unknown-platform research runs on a durable Render Workflow. The web service
# starts and reads runs; the Workflow service does the actual research. Copy to
# .env for local dev. On Render, set these as secrets on the correct resource.

# --- Web service (developer-journey-atlas): starts/reads Workflow runs ---
# Secret Render API key used server-side by @renderinc/sdk. Never exposed to the
# browser. Create one at https://dashboard.render.com/settings#api-keys
RENDER_API_KEY=

# Registered parent task slug, from the Workflow's task page in the Dashboard.
RENDER_WORKFLOW_TASK_SLUG=developer-journey-atlas-workflows/researchPlatform

# For local dev against `render workflows dev`, point the SDK at the local
# task server instead of api.render.com:
# RENDER_USE_LOCAL_DEV=true

# --- Workflow service (developer-journey-atlas-workflows): does the research ---
# You.com Web Search API key. https://you.com/platform
YDC_API_KEY=

# OpenRouter API key for LLM record reconstruction. https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Required for OpenRouter (it has no server-side default; omitting this fails with
# "No models provided"). No model is pinned in code, so choose one here.
OPENROUTER_MODEL=openai/gpt-4.1-mini

# Optional: least-privilege GitHub token (contents + pull requests on
# ojusave/developer-journey-atlas) to open draft PRs. Without it, research still
# runs and the drafted record is offered for manual submission.
GITHUB_TOKEN=

# Optional: override the contribution target repo (owner/repo).
# GITHUB_REPO_SLUG=ojusave/developer-journey-atlas
